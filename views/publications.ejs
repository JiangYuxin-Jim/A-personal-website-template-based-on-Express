<%- include('partials/head', { title, currentPage }) %>

<button class="lang-toggle" onclick="toggleLang()" aria-label="Switch language">
  <span class="zh">EN</span><span class="en">中</span>
</button>

<div class="page-wrapper">
  <%- include('partials/sidebar') %>

  <main class="main-content">
    <%- include('partials/nav', { currentPage }) %>

    <section class="content-section">
      <h2 class="section-title"><span class="zh">发表与获奖</span><span class="en">Publications &amp; Awards</span></h2>
      <div class="pub-list">
        <% items.forEach(function(pub) { %>
          <div class="pub-entry" style="display:flex;gap:16px;padding:14px 18px;background:var(--card-bg);border-radius:8px;border:1px solid var(--border-light);font-size:13.5px;line-height:1.6;transition:background 0.15s;">
            <span class="honor-entry-year"><%= pub.year %></span>
            <div style="flex:1;min-width:0;">
              <% if (pub.title) { %>
                <div class="pub-entry-title"><%= pub.title %></div>
              <% } else { %>
                <div class="pub-entry-title"><span class="zh"><%= pub.title_zh %></span><span class="en"><%= pub.title_en %></span></div>
              <% } %>
              <% if (pub.venue) { %>
                <div class="pub-entry-venue"><%= pub.venue %></div>
              <% } else if (pub.venue_zh) { %>
                <div class="pub-entry-venue"><span class="zh"><%= pub.venue_zh %></span><span class="en"><%= pub.venue_en %></span></div>
              <% } %>
              <% if (pub.doi) { %>
                <div class="pub-entry-doi">DOI: <a href="<%= pub.link || 'https://doi.org/' + pub.doi %>" target="_blank" rel="noopener"><%= pub.doi %></a></div>
              <% } %>
              <% if (pub.summary_zh) { %>
                <div class="pub-entry-doi"><span class="zh"><%= pub.summary_zh %></span><span class="en"><%= pub.summary_en %></span></div>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </main>
</div>

<%- include('partials/scripts', { currentPage }) %>
