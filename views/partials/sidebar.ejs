<aside class="sidebar">
  <a href="/" style="text-decoration:none;color:inherit;">
    <div class="sidebar-photo">
      <% if (site.avatar) { %>
        <img src="<%= site.avatar %>" alt="<%= site.name %>">
      <% } else { %>
        <span class="sidebar-photo-placeholder"><%= site.initial %></span>
      <% } %>
    </div>
    <div class="sidebar-name">
      <span class="zh"><%= site.name %></span>
      <span class="en"><%= site.nameEn %></span>
    </div>
  </a>
  <div class="sidebar-title">
    <span class="zh"><%= site.title %></span>
    <span class="en"><%= site.titleEn %></span>
  </div>
  <div class="sidebar-school">
    <span class="zh"><%= site.school %></span>
    <span class="en"><%= site.schoolEn %></span>
  </div>

  <div class="sidebar-links-v">
    <% if (site.github && site.github !== 'yourusername') { %>
    <a href="https://github.com/<%= site.github %>" target="_blank" rel="noopener" class="sidebar-link-v">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      <span><%= site.github %></span>
    </a>
    <% } %>
    <% if (site.email && site.email !== 'your.email@example.com') { %>
    <a href="mailto:<%= site.email %>" class="sidebar-link-v">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
      <span><%= site.email %></span>
    </a>
    <% } %>
  </div>

  <% if (site.researchInterests && site.researchInterests.length > 0) { %>
  <div class="sidebar-card">
    <div class="sidebar-card-title">
      <span class="zh" style="font-size: 18px;">研究方向</span><span class="en" style="font-size: 18px;">Research Interests</span>
    </div>
    <ul>
      <% site.researchInterests.forEach(function(ri) { %>
        <li><span class="zh" style="font-size: 16px;"><%= ri.zh %></span><span class="en" style="font-size: 16px;"><%= ri.en %></span></li>
      <% }) %>
    </ul>
  </div>
  <% } %>
</aside>
