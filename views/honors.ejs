<%- include('partials/head', { title, currentPage }) %>

<button class="lang-toggle" onclick="toggleLang()" aria-label="Switch language">
  <span class="zh">EN</span><span class="en">中</span>
</button>

<div class="page-wrapper">
  <%- include('partials/sidebar') %>

  <main class="main-content">
    <nav class="section-nav">
      <a href="/"><span class="zh">关于</span><span class="en">About</span></a>
      <a href="/blog"><span class="zh">博客</span><span class="en">Blog</span></a>
      <a href="/publications"><span class="zh">发表</span><span class="en">Publications</span></a>
      <a href="/honors" class="active"><span class="zh">荣誉</span><span class="en">Honors</span></a>
    </nav>

    <section class="content-section">
      <h2 class="section-title"><span class="zh">荣誉与经历</span><span class="en">Honors &amp; Experience</span></h2>
      <div class="honor-list">
        <% items.forEach(function(h) { %>
          <div class="honor-entry">
            <span class="honor-entry-year"><%= h.year %></span>
            <div class="honor-entry-body">
              <div class="honor-entry-title">
                <span class="zh"><%= h.title_zh %></span>
                <span class="en"><%= h.title_en %></span>
              </div>
              <% if (h.desc_zh) { %>
                <div class="honor-entry-desc">
                  <span class="zh"><%= h.desc_zh %></span>
                  <span class="en"><%= h.desc_en %></span>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </main>
</div>

<%- include('partials/scripts', { currentPage }) %>
