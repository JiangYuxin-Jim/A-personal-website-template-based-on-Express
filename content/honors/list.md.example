section: honors

# 每条记录支持的字段：
#   year     - 年份（显示在左侧）
#   title_zh - 中文标题（必填）
#   title_en - 英文标题
#   desc_zh  - 中文描述（可选，显示在标题下方）
#   desc_en  - 英文描述（可选）

items:

  - year: "2026"
    title_zh: "中文标题"
    title_en: "English Title"

  - year: "2025"
    title_zh: "带描述的中文标题"
    title_en: "English Title with Description"
    desc_zh: "中文描述文字，显示在标题下方"
    desc_en: "English description shown below the title"

  - year: "2024"
    title_zh: "只有中文没有英文"
    # title_en 不写就只显示中文
